{
  "name": "lead-radar-worker",
  "version": "0.1.0",
  "description": "Local worker for Lead Radar, performing background scraping via Playwright",
  "author": "SonusPrime",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "setup:local-ai": "tsx scripts/setup-local-ai.ts",
    "start": "electron dist/main.js",
    "dev": "concurrently \"tsc -w\" \"electron dist/main.js\"",
    "dev:ts": "ts-node main.ts",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "playwright": "^1.49.1"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^24.13.3",
    "concurrently": "^10.0.3",
    "typescript": "^5.7.2",
    "@types/node": "^20.11.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17"
  },
  "build": {
    "appId": "com.leadradar.worker",
    "productName": "Lead Radar Worker",
    "electronVersion": "33.2.1",
    "icon": "assets/icon.ico",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Lead Radar Worker"
    }
  }
}
